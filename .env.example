# OpenAI
OPENAI_API_KEY=sk-...
# Optional: model used for analysis (default: gpt-4o-mini)
SIMONW_OPENAI_MODEL=gpt-4o-mini
# Optional: custom base URL (e.g. self-hosted gateway, Azure-compatible endpoints)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Telegram bot (only needed for the bot, not for the CLI / skill)
TELEGRAM_BOT_TOKEN=123456:ABCDEF...

# Optional: comma-separated list of Telegram user IDs allowed to use the bot.
# Leave empty to allow everyone.
TELEGRAM_ALLOWED_USER_IDS=

# Output language for analysis (default: zh). Set to "en" for English.
SIMONW_OUTPUT_LANG=zh

# Maximum number of referenced links analysed per post (default: 8)
SIMONW_MAX_REFERENCES=8
